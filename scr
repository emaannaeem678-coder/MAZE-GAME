class UserAuth {

    static final String USER_FILE = "projectdsa.txt";

    static boolean register(String u, String p) {
        try {
            File f = new File(USER_FILE);
            if (!f.exists()) f.createNewFile();

            Scanner sc = new Scanner(f);
            while (sc.hasNextLine())
                if (sc.nextLine().startsWith(u + ",")) {
                    sc.close();
                    return false;
                }
            sc.close();

            FileWriter fw = new FileWriter(f, true);
            fw.write(u + "," + p + "\n");
            fw.close();
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    static boolean login(String u, String p) {
        try {
            File f = new File(USER_FILE);
            if (!f.exists()) return false;

            Scanner sc = new Scanner(f);
            while (sc.hasNextLine()) {
                String[] d = sc.nextLine().split(",");
                // String line = sc.nextLine().trim();
                //String[] d = line.split(",");
                if (d[0].equals(u) && d[1].equals(p)) {
                    sc.close();
                    return true;
                }
            }
            sc.close();
        } catch (Exception e) {}
        return false;
    }
}


